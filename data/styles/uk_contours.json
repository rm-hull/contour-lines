{
  "version": 8,
  "name": "UK Contours",
  "sources": {
    "uk_contours": {
      "type": "vector",
      "url": "mbtiles://uk_contours"
    }
  },
  "layers": [
    {
      "id": "contour-lines",
      "type": "line",
      "source": "uk_contours",
      "source-layer": "uk_contours",
      "paint": {
        "line-color": "#8B6914",
        "line-width": [
          "interpolate", ["linear"], ["zoom"],
          8, 0.5,
          14, 1.5
        ],
        "line-opacity": 0.6
      }
    },
    {
      "id": "contour-index",
      "type": "line",
      "source": "uk_contours",
      "source-layer": "uk_contours",
      "filter": ["==", ["%", ["get", "elev"], 50], 0],
      "paint": {
        "line-color": "#6B4F0A",
        "line-width": [
          "interpolate", ["linear"], ["zoom"],
          9, 0,
          10, 2
        ],
        "line-opacity": 0.5
      }
    },
    {
      "id": "contour-labels",
      "type": "symbol",
      "source": "uk_contours",
      "source-layer": "uk_contours",
      "filter": ["==", ["%", ["get", "elev"], 50], 0],
      "layout": {
        "symbol-placement": "line",
        "text-field": "{elev}m",
        "text-size": 10
      },
      "paint": {
        "text-color": "#6B4F0A",
        "text-halo-color": "#fff",
        "text-halo-width": 1
      }
    }
  ]
}
